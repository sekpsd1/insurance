## Prisma / database connection
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"

## Admin login password for /admin/login
ADMIN_PASSWORD="ChangeThisToAStrongPassword"
ADMIN_SESSION_SECRET="ChangeThisToASeparateLongRandomSecret"

## Public base URL used in provider Magic Link emails, for example https://insurance.example.com
APP_BASE_URL="http://localhost:3000"

## Provider email delivery. Use mock only for local development.
EMAIL_PROVIDER="mock"
EMAIL_FROM="Insurance Broker <noreply@example.com>"
RESEND_API_KEY=""

## Local uploads are fine for local/dev. In production, prefer object storage.
## Set this to true only if the host has persistent disk storage.
UPLOAD_STORAGE_DRIVER="local"
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION="false"

## S3-compatible object storage for uploads. Works with AWS S3, Cloudflare R2, MinIO, etc.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

## Optional LINE user id used by the order form when none is provided in the URL
DEMO_LINE_ID="demo-line-id"

## Public LINE MINI App / LIFF id used by customer pages to read LINE profile
NEXT_PUBLIC_LIFF_ID=""

## Optional values used by the Docker backup helper
MYSQL_ROOT_PASSWORD="ChangeThisIfYouUseDockerBackup"
MYSQL_CONTAINER_NAME="insurance-db-1"

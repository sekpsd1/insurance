generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  lineId      String    @unique
  name        String?
  phone       String?
  email       String?
  consentedAt DateTime?
  orders      Order[]
  createdAt   DateTime  @default(now())
}

model InsurancePackage {
  id                   String   @id @default(uuid())
  name                 String
  company              String
  companyCode          String?
  campaignCode         String?
  campaignName         String?
  providerName         String?
  providerEmail        String?
  providerContactName  String?
  providerPhone        String?
  paymentBankName      String?
  paymentAccountName   String?
  paymentAccountNumber String?
  paymentQrUrl         String?
  paymentUrl           String?
  paymentNotes         String?  @db.Text
  brand                String?
  model                String?
  year                 Int?
  sClass               String?
  minSumInsured        Int?
  maxSumInsured        Int?
  minCarAge            Int?
  maxCarAge            Int?
  minCubicCapacity     Int?
  maxCubicCapacity     Int?
  rawData              Json?
  logoUrl              String?
  details              String?
  repairType           String?
  coverage             String?
  fullPrice            Float
  netPrice             Float
  payablePrice         Float?
  discount             Float
  orders               Order[]
  createdAt            DateTime @default(now())

  @@index([companyCode, campaignCode])
  @@index([brand, model, year])
  @@index([sClass, minSumInsured, maxSumInsured])
}

model CtpRate {
  id                 String   @id @default(uuid())
  sClass             String   @unique
  rateCode           String?
  cmiVehicleTypeCode String?
  label              String
  eligibilityLabel   String?
  premium            Float    @default(0)
  stamp              Float    @default(0)
  vat                Float    @default(0)
  total              Float    @default(0)
  sellable           Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Order {
  id          String           @id @default(uuid())
  orderNumber String           @unique
  status      String           @default("DRAFT")
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  packageId   String
  pkg         InsurancePackage @relation(fields: [packageId], references: [id])

  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String? @db.Text
  province        String?
  district        String?
  subDistrict     String?
  postalCode      String?
  idCardNumber    String?

  carBrand        String?
  carModel        String?
  carYear         Int?
  plateNumber     String?
  plateProvince   String?
  policyStartDate DateTime?

  paymentMethod      String?
  paymentStatus      String    @default("UNPAID")
  paymentAmount      Float?
  ctpSelected        Boolean   @default(false)
  ctpRateCode        String?
  ctpVehicleTypeCode String?
  ctpPremium         Float?
  ctpStamp           Float?
  ctpVat             Float?
  ctpTotal           Float?
  slipUrl            String?
  gatewayUrl         String?
  paidAt             DateTime?

  trackingNumber   String?
  insurerStatus    String?
  insurerNote      String?              @db.Text
  insurerUpdatedAt DateTime?
  statusHistory    OrderStatusHistory[]
  magicLinks       MagicLinkToken[]
  emailOutbox      EmailOutbox[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  message   String?  @db.Text
  actorType String   @default("SYSTEM")
  actorName String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model MagicLinkToken {
  id        String    @id @default(uuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  purpose   String    @default("INSURER_STATUS_UPDATE")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderId])
}

model EmailOutbox {
  id            String    @id @default(uuid())
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  recipient     String?
  subject       String
  body          String    @db.Text
  magicLinkPath String?
  status        String    @default("QUEUED")
  sentAt        DateTime?
  errorAt       DateTime?
  errorMessage  String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orderId, createdAt])
  @@index([status])
}
